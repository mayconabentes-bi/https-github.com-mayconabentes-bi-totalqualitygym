rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function getUser() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }

    // Role helpers
    function isDirection() { return isSignedIn() && getUser().role == 'direction'; }
    function isPartner() { return isSignedIn() && getUser().role == 'partner'; }
    function isTechnicalAdvice() { return isSignedIn() && getUser().role == 'technical_advice'; }
    function isTeacher() { return isSignedIn() && getUser().role == 'teacher'; }
    
    // Multi-tenant check
    function isTenantMember(tenantId) {
      return isSignedIn() && getUser().tenantId == tenantId;
    }

    // --- Entity Validations ---
    function isValidUser(data) {
      return data.email is string && data.email.size() <= 200
          && data.role in ['direction', 'partner', 'technical_advice', 'teacher']
          && data.tenantId is string && data.tenantId.size() <= 128
          && data.displayName is string && data.displayName.size() <= 200;
    }

    function isValidPolicy(data) {
      return data.content is string && data.content.size() <= 50000
          && data.version is string && data.version.size() <= 50
          && data.status in ['DRAFT', 'UNDER_REVIEW', 'APPROVED', 'PUBLISHED', 'SUPERSEDED']
          && data.tenantId is string && data.tenantId.size() <= 128;
    }

    function isAdminOrPartner() {
      return isDirection() || isPartner();
    }

    function canModifyDraft(data) {
      return isTechnicalAdvice() || isTeacher() || isAdminOrPartner();
    }

    function isValidPlan(data) {
      return data.year is int && data.year >= 2000 && data.year <= 2100
          && data.tenantId is string && data.tenantId.size() <= 128;
    }

    function isValidStakeholder(data) {
      return data.name is string && data.name.size() <= 500
          && data.tenantId is string && data.tenantId.size() <= 128;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUser().tenantId == existing().tenantId));
      allow list: if isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && resource.data.tenantId == getUser().tenantId;
      
      // Allow self-registration during initial login
      allow create: if isSignedIn() && (
        (request.auth.uid == userId && incoming().role == 'teacher') || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && isDirection() && incoming().tenantId == getUser().tenantId)
      ) && isValidUser(incoming());
      
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['displayName'])) ||
        (isDirection() && incoming().tenantId == existing().tenantId && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'role', 'auditorLevel', 'averageScore'])) ||
        // Allow auditees to update auditor score indirectly (risky but needed for this demo flow)
        (isTenantMember(existing().tenantId) && incoming().diff(existing()).affectedKeys().hasOnly(['auditorLevel', 'averageScore']))
      );
    }

    match /tenants/{tenantId} {
      allow get: if isSignedIn(); // Allow reading tenant info to check membership
      allow list: if false;
      
      // Allow creation of first tenant during demo bootstrapping
      allow create: if isSignedIn() && tenantId == 'area-fit-main';

      match /policies/{policyId} {
        allow read: if isTenantMember(tenantId);
        
        // Creation logic: can start as DRAFT
        allow create: if isTenantMember(tenantId) 
                      && isValidPolicy(incoming()) 
                      && incoming().tenantId == tenantId
                      && incoming().status == 'DRAFT';

        // Update logic: state machine
        allow update: if isTenantMember(tenantId) 
                      && isValidPolicy(incoming()) 
                      && incoming().tenantId == tenantId
                      && (
                        // 1. DRAFT -> UNDER_REVIEW (Anyone can submit)
                        (existing().status == 'DRAFT' && incoming().status == 'UNDER_REVIEW') ||
                        
                        // 2. UNDER_REVIEW -> APPROVED (Only Direction/Partner)
                        (existing().status == 'UNDER_REVIEW' && incoming().status == 'APPROVED' && isAdminOrPartner()) ||
                        
                        // 3. APPROVED -> PUBLISHED (Only Direction/Partner)
                        (existing().status == 'APPROVED' && incoming().status == 'PUBLISHED' && isAdminOrPartner()) ||
                        
                        // 4. PUBLISHED -> SUPERSEDED (System triggered when new one is published - for now allowing admins)
                        (existing().status == 'PUBLISHED' && incoming().status == 'SUPERSEDED' && isAdminOrPartner()) ||

                        // 5. Allowed to edit content if DRAFT
                        (existing().status == 'DRAFT' && incoming().status == 'DRAFT' && canModifyDraft(incoming()))
                      );
      }

      match /audit_logs/{id} {
        allow read: if isTenantMember(tenantId);
        allow create: if isSignedIn() && isTenantMember(tenantId);
      }

      match /stakeholders/{id} {
        allow read: if isTenantMember(tenantId);
        allow create: if (isDirection() || isPartner() || isTechnicalAdvice()) && isTenantMember(tenantId) && isValidStakeholder(incoming()) && incoming().tenantId == tenantId;
        allow update: if (isDirection() || isPartner() || isTechnicalAdvice()) && isTenantMember(tenantId) && isValidStakeholder(incoming())
                      && incoming().tenantId == tenantId
                      && (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'needs', 'expectations']));
      }

      match /plans/{id} {
        allow read: if isTenantMember(tenantId);
        allow create: if (isDirection() || isPartner() || isTechnicalAdvice()) && isTenantMember(tenantId) && isValidPlan(incoming()) && incoming().tenantId == tenantId;
        allow update: if (isDirection() || isPartner() || isTechnicalAdvice()) && isTenantMember(tenantId) && isValidPlan(incoming())
                      && incoming().tenantId == tenantId
                      && (incoming().diff(existing()).affectedKeys().hasOnly(['mission', 'vision', 'values', 'year']));
      }

      match /objectives/{id} {
        allow read: if isTenantMember(tenantId);
        allow create: if (isDirection() || isPartner() || isTechnicalAdvice() || isTeacher()) && isTenantMember(tenantId) && incoming().tenantId == tenantId;
        allow update: if (isDirection() || isPartner() || isTechnicalAdvice() || isTeacher()) && isTenantMember(tenantId)
                      && incoming().tenantId == tenantId
                      && (incoming().diff(existing()).affectedKeys().hasOnly(['title', 'target', 'result', 'planId', 'currentValue', 'targetValue']));
      }

      match /checkins/{id} {
        allow read: if isTenantMember(tenantId);
        allow create: if isTeacher() && isTenantMember(tenantId) && incoming().tenantId == tenantId;
      }

      match /audit_programs/{id} {
        allow read: if isTenantMember(tenantId);
        allow write: if (isDirection() || isPartner() || isTechnicalAdvice()) && isTenantMember(tenantId) && incoming().tenantId == tenantId;
      }

      match /audit_plans/{id} {
        allow read: if isTenantMember(tenantId);
        allow create: if (isDirection() || isPartner() || isTechnicalAdvice()) && isTenantMember(tenantId) && incoming().tenantId == tenantId;
        allow update: if isTenantMember(tenantId) && incoming().tenantId == tenantId && (
          // General updates for DRAFT
          (existing().status == 'DRAFT' && (isDirection() || isPartner() || isTechnicalAdvice())) ||
          // Homologation (Only Direction/Partner)
          (incoming().status == 'SCHEDULED' && existing().status == 'DRAFT' && isAdminOrPartner() && incoming().homologatedBy != null) ||
          // Progress updates
          (isAdminOrPartner() || isTechnicalAdvice())
        );

        match /schedule/{itemId} {
          allow read: if isTenantMember(tenantId);
          allow write: if (isDirection() || isPartner() || isTechnicalAdvice()) && isTenantMember(tenantId);
        }

        match /responses/{responseId} {
          allow read: if isTenantMember(tenantId);
          allow write: if isTenantMember(tenantId) && (isAdminOrPartner() || isTechnicalAdvice());
        }
      }

      match /audit_reports/{id} {
        allow read: if isTenantMember(tenantId);
        allow create: if isTenantMember(tenantId) && (isAdminOrPartner() || isTechnicalAdvice());
        allow update: if isTenantMember(tenantId) && (
          (existing().status == 'DRAFT' && (isAdminOrPartner() || isTechnicalAdvice())) ||
          (incoming().status == 'APPROVED' && isAdminOrPartner())
        );
      }
      
      match /auditor_evaluations/{id} {
        allow read: if isTenantMember(tenantId);
        allow create: if isTenantMember(tenantId);
      }

      match /non_conformities/{id} {
        allow read: if isTenantMember(tenantId);
        allow create: if isTenantMember(tenantId);
        allow update: if isTenantMember(tenantId) && (isDirection() || isPartner() || isTechnicalAdvice());
        allow delete: if false; // Immutability as per auditing best practices
      }

      match /corrective_actions/{id} {
        allow read: if isTenantMember(tenantId);
        allow create: if isTenantMember(tenantId) && (isDirection() || isPartner() || isTechnicalAdvice());
        allow update: if isTenantMember(tenantId) && (isDirection() || isPartner() || isTechnicalAdvice());
      }

      match /audit_checklists/{id} {
        allow read: if isTenantMember(tenantId);
        allow write: if (isDirection() || isPartner() || isTechnicalAdvice()) && isTenantMember(tenantId);
      }

      match /metrics/{id} {
        allow read: if isTenantMember(tenantId);
        allow create: if (isDirection() || isPartner() || isTechnicalAdvice()) && isTenantMember(tenantId);
      }
    }
  }
}
